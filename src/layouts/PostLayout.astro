---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import { formatDate } from "@/consts";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type AdjacentPost = {
  title: string;
  slug: string;
  date: Date;
};

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: string;
  headings?: Heading[];
  newerPost?: AdjacentPost;
  olderPost?: AdjacentPost;
}

const { title, description, date, tags, cover, headings = [], newerPost, olderPost } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishedTime={date}
  tags={tags}
>
  <article class="reading-wrap">
    <a href="/blog" class="nav-link inline-flex items-center gap-2 text-sm">
      <span aria-hidden="true">&larr;</span>
      <span>Back to Blog</span>
    </a>

    <header class="page-header mt-4">
      <p class="text-sm text-muted">{formatDate(date)}</p>
      <h1 class="post-title mt-3">{title}</h1>
      <p class="mt-4 text-lg text-muted">{description}</p>

      {tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag) => <Tag label={tag} />)}
        </div>
      )}
    </header>

    {headings.length > 1 && (
      <aside class="mt-8 rounded-lg border border-border p-4">
        <p class="text-sm font-medium text-text">On this page</p>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {headings
            .filter((heading) => heading.depth <= 3)
            .map((heading) => (
              <li class:list={[heading.depth > 2 && "ml-4"]}>
                <a href={`#${heading.slug}`} class="transition-colors duration-200 hover:text-accent">
                  {heading.text}
                </a>
              </li>
            ))}
        </ul>
      </aside>
    )}

    {cover && <img src={cover} alt={title} class="mt-8 w-full rounded-lg border border-border" loading="lazy" />}

    <div class="article-body">
      <slot />
    </div>

    {(newerPost || olderPost) && (
      <nav class="mt-14 border-t border-border pt-8" aria-label="Post navigation">
        <p class="text-sm text-muted">Continue reading</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {newerPost ? (
            <a href={`/blog/${newerPost.slug}`} class="card-surface block p-4">
              <p class="text-xs uppercase tracking-[0.08em] text-muted">Newer</p>
              <p class="mt-2 text-base font-medium text-text transition-colors duration-200 hover:text-accent">
                {newerPost.title}
              </p>
              <p class="mt-2 text-sm text-muted">{formatDate(newerPost.date)}</p>
            </a>
          ) : (
            <div></div>
          )}

          {olderPost && (
            <a href={`/blog/${olderPost.slug}`} class="card-surface block p-4">
              <p class="text-xs uppercase tracking-[0.08em] text-muted">Older</p>
              <p class="mt-2 text-base font-medium text-text transition-colors duration-200 hover:text-accent">
                {olderPost.title}
              </p>
              <p class="mt-2 text-sm text-muted">{formatDate(olderPost.date)}</p>
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</BaseLayout>
