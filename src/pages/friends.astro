---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const friends = [
	{
		name: "Watermelon",
		url: "https://blog.westmelon.de/",
		domain: "blog.westmelon.de",
		description: "Personal blog.",
		tags: ["Blog"],
		avatar: "W",
		avatarUrl: "https://blog.westmelon.de/waTerME1oN_files/watermelon.jpg",
	},
	{
		name: "Kingsley",
		url: "https://blog.agmcs.net/",
		domain: "blog.agmcs.net",
		description: "Personal blog.",
		tags: ["Blog"],
		avatar: "K",
		avatarUrl: "",
	},
];
const tags = Array.from(new Set(friends.flatMap((friend) => friend.tags)));
---

<MainGridLayout title="Friends" description="Friends">
    <div class="card-base px-6 md:px-9 py-7 mb-4">
        <header class="mb-8">
            <h1 class="font-bold transition text-4xl text-neutral-900 dark:text-neutral-100 relative ml-3 mb-2
                before:w-1 before:h-8 before:rounded-md before:bg-[var(--primary)]
                before:absolute before:-left-4 before:top-1"
            >
                <span data-i18n-custom="friends">Friends</span>
            </h1>
            <p class="transition text-50 text-lg" data-i18n-custom="friendsSubtitle">
                Discover more excellent websites
            </p>
        </header>

        <div class="relative mb-3">
            <Icon name="material-symbols:search" class="absolute text-[1.25rem] pointer-events-none left-4 top-1/2 -translate-y-1/2 transition text-black/30 dark:text-white/30"></Icon>
            <input
                id="friends-search"
                data-i18n-custom-placeholder="searchFriends"
                placeholder="Search by friend name or description..."
                class="transition-all w-full h-11 pl-12 pr-4 rounded-lg outline-0 text-sm
                    bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)]
                    focus:bg-[var(--btn-regular-bg-hover)] text-black/60 dark:text-white/60"
            >
        </div>

        <div id="friends-filter" class="flex flex-wrap gap-2 mb-6">
            <button data-filter="all" class="friend-filter btn-regular rounded-xl h-10 px-4 text-sm font-bold current-theme-btn">
                <span data-i18n-custom="all">All</span>
            </button>
            {tags.map((tag) => (
                <button data-filter={tag} class="friend-filter btn-regular rounded-xl h-10 px-4 text-sm font-medium">
                    {tag}
                </button>
            ))}
        </div>

        <div id="friends-grid" class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {friends.map((friend, index) => (
                <article
                    class="friend-card group transition-all duration-300 border border-black/10 dark:border-white/10 rounded-xl p-5 bg-[var(--card-bg)]
                        hover:-translate-y-1 hover:border-[var(--primary)] hover:shadow-xl hover:shadow-black/5 dark:hover:shadow-none
                        active:scale-[0.99]"
                    style={`--friend-delay: ${index * 90}ms`}
                    data-name={friend.name.toLowerCase()}
                    data-description={friend.description.toLowerCase()}
                    data-tags={friend.tags.join(" ").toLowerCase()}
                >
                    <div class="flex items-center gap-4 mb-4">
                        <div class="h-14 w-14 shrink-0 rounded-xl overflow-hidden flex items-center justify-center
                            bg-[var(--btn-regular-bg)] text-[var(--primary)] text-2xl font-bold
                            transition-transform duration-300 group-hover:scale-105"
                        >
                            {friend.avatarUrl ? <img src={friend.avatarUrl} alt={`${friend.name} avatar`} class="h-full w-full object-cover" loading="lazy" /> : friend.avatar}
                        </div>
                        <div class="min-w-0">
                            <h2 class="transition text-xl font-bold text-90 truncate">{friend.name}</h2>
                            <a href={friend.url} target="_blank" class="transition text-sm font-medium text-[var(--primary)] underline decoration-[var(--link-underline)] decoration-dashed underline-offset-4 hover:decoration-[var(--link-hover)] truncate block">
                                {friend.domain}
                            </a>
                        </div>
                    </div>

                    <p class="transition text-50 text-sm h-12 mb-1 leading-6 line-clamp-2 overflow-hidden">
                        {friend.description}
                    </p>

                    <div class="flex flex-wrap gap-2 mb-4">
                        {friend.tags.map((tag) => (
                            <span class="transition text-xs font-medium text-[var(--primary)]">
                                {tag}
                            </span>
                        ))}
                    </div>

                    <div class="flex gap-2">
                        <a href={friend.url} target="_blank" class="btn-regular rounded-lg h-9 flex-1 font-bold active:scale-95">
                            <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] mr-2 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"></Icon>
                            <span data-i18n-custom="visit">Visit</span>
                        </a>
                        <button data-copy-url={friend.url} data-i18n-custom-aria-label="copyLink" aria-label="Copy link" class="friend-copy btn-regular rounded-lg h-9 w-10 active:scale-95">
                            <Icon name="fa6-regular:copy" class="text-[1rem]"></Icon>
                        </button>
                    </div>
                </article>
            ))}
        </div>
    </div>
</MainGridLayout>

<style>
    .friend-card {
        animation: friend-card-in 0.45s ease-out both;
        animation-delay: var(--friend-delay);
        will-change: transform, opacity;
    }

    @keyframes friend-card-in {
        from {
            opacity: 0;
            transform: translateY(0.75rem) scale(0.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .friend-card {
            animation: none;
        }
    }
</style>

<script>
function initFriendsPage() {
	const searchInput = document.getElementById("friends-search") as HTMLInputElement | null;
	const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".friend-filter"));
	const cards = Array.from(document.querySelectorAll<HTMLElement>(".friend-card"));
	const copyButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".friend-copy"));
	let activeFilter = "all";

	function applyFilter() {
		const keyword = searchInput?.value.trim().toLowerCase() || "";
		for (const card of cards) {
			const matchesFilter =
				activeFilter === "all" ||
				(card.dataset.tags || "").split(" ").includes(activeFilter.toLowerCase());
			const searchable = `${card.dataset.name || ""} ${card.dataset.description || ""} ${card.dataset.tags || ""}`;
			const matchesSearch = !keyword || searchable.includes(keyword);
			card.classList.toggle("hidden", !(matchesFilter && matchesSearch));
		}
	}

	searchInput?.addEventListener("input", applyFilter);

	for (const button of filterButtons) {
		button.addEventListener("click", () => {
			activeFilter = button.dataset.filter || "all";
			for (const item of filterButtons) {
				item.classList.toggle("current-theme-btn", item === button);
			}
			applyFilter();
		});
	}

	for (const button of copyButtons) {
		button.addEventListener("click", async () => {
			const url = button.dataset.copyUrl;
			if (!url) return;
			await navigator.clipboard.writeText(url);
		});
	}
}

initFriendsPage();
document.addEventListener("swup:page:view", initFriendsPage);
</script>
