---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Alex (Onuty), this blog, and what I am writing about.">
  <section class="reading-wrap">
    <header class="page-header">
      <h1 class="page-title">About</h1>
    </header>

    <div class="article-body">
      <p>
        I am Alex, also known as Onuty. I write about programming, computer technology, game development, and
        personal projects.
      </p>
      <p>
        This site is a minimal Astro blog focused on readability, generous whitespace, and straightforward writing.
      </p>
      <p>
        The previous WordPress frontend remains as an archive while this site focuses on a clean and fast reading
        experience.
      </p>
    </div>
  </section>
</BaseLayout>
