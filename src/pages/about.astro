---

import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-7 relative w-full">
            <h1 class="font-bold transition text-3xl text-neutral-900 dark:text-neutral-100 relative ml-3 mb-4
                before:w-1 before:h-6 before:rounded-md before:bg-[var(--primary)]
                before:absolute before:-left-4 before:top-1"
            >
                <span data-i18n-custom="aboutTitle">About</span>
            </h1>
            <div class="transition text-75 leading-8 space-y-4">
                <p data-i18n-custom="aboutIntro">This is Onuty's personal blog.</p>
                <p data-i18n-custom="aboutDetail">I use this space to collect technical notes, personal writing, and links worth keeping.</p>
            </div>
        </div>
    </div>
</MainGridLayout>
