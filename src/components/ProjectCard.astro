---
import type { Project } from "@/consts";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card-surface flex h-full flex-col justify-between">
  <div>
    <h3 class="text-xl font-semibold tracking-tight text-text">{project.name}</h3>
    <p class="mt-3 text-muted">{project.description}</p>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-muted">
    <a class="transition-colors duration-200 hover:text-accent" href={project.github} target="_blank" rel="noreferrer">
      GitHub
    </a>
    {project.demo && (
      <a class="transition-colors duration-200 hover:text-accent" href={project.demo} target="_blank" rel="noreferrer">
        Demo
      </a>
    )}
    {project.stars && <span aria-label="Stars">Stars: {project.stars}</span>}
  </div>
</article>
