---
import { formatDate } from "@/consts";
import Tag from "@/components/Tag.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
  cover?: string;
}

const { title, description, date, tags, href, cover } = Astro.props;
---

<article class="card-surface">
  {cover && (
    <a href={href} class="mb-5 block overflow-hidden rounded-lg border border-border bg-[#fafafa]">
      <img
        src={cover}
        alt={title}
        loading="lazy"
        decoding="async"
        class="aspect-[16/9] w-full object-cover"
      />
    </a>
  )}

  <p class="text-sm text-muted">{formatDate(date)}</p>
  <h3 class="mt-3 text-2xl font-semibold tracking-tight text-text">
    <a href={href} class="title-link">{title}</a>
  </h3>
  <p class="mt-3 text-muted">{description}</p>

  {tags.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => <Tag label={tag} />)}
    </div>
  )}
</article>
