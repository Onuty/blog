---
import { GISCUS } from "@/consts";

const enabled = Boolean(GISCUS.repo && GISCUS.repoId && GISCUS.category && GISCUS.categoryId);
---

<section class="mt-16 border-t border-border pt-10">
  <h2 class="text-2xl font-semibold tracking-tight text-text">Comments</h2>

  {enabled ? (
    <div class="mt-6">
      <script
        src="https://giscus.app/client.js"
        data-repo={GISCUS.repo}
        data-repo-id={GISCUS.repoId}
        data-category={GISCUS.category}
        data-category-id={GISCUS.categoryId}
        data-mapping={GISCUS.mapping}
        data-strict={GISCUS.strict}
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="light"
        data-lang="en"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  ) : (
    <p class="mt-4 text-sm text-muted">
      Configure giscus environment variables to enable comments.
    </p>
  )}
</section>

